def test_session__empty_registration_input_is_rejected() -> None:
    """register should reject empty logical names and empty source URIs with invalid_registration."""
    # -- Arrange --
    mut session = Session.default()

    # -- Act & Assert --
    match session.register("", csv_source(ORDERS_CSV_FIXTURE)):
        Ok(_) => 
            assert false, "expected empty logical name to fail"
        Err(err) => 
            assert err.kind == "invalid_registration", "empty logical names should be rejected"

    match session.register("orders", csv_source("")):
        Ok(_) => 
            assert false, "expected empty source uri to fail"
        Err(err) => 
            assert err.kind == "invalid_registration", "empty source uris should be rejected"

