@FUNCTION_REGISTRY.add("str_expr", deterministic_spec(
    FunctionClass.Scalar,
    FunctionLifecycle(since=V0_1, changed=[], deprecated=None),
    signature([literal_arg("value", "str")], "ColumnExpr"),
    FunctionNullBehavior.NonNullLiteral,
    rewrite_mapping("typed string literal expression"),
))
pub def str_expr(value: str) -> ColumnExpr:
    """Build one string literal expression."""
