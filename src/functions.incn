    FunctionLifecycle(since=V0_1, changed=[], deprecated=None),
    signature([literal_arg("value", "float")], "ColumnExpr"),
    FunctionNullBehavior.NonNullLiteral,
    rewrite_mapping("typed floating-point literal expression"),
))
pub def float_expr(value: float) -> ColumnExpr:
    """Build one float literal expression."""
